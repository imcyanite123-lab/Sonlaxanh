{
  "entities": {
    "TrashReport": {
      "title": "Trash Report",
      "description": "A report of a trash pile submitted by a user",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "locationName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "high"] },
        "reporterId": { "type": "string" },
        "reporterName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "cleaned"] },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "createdAt": { "type": "object" }
      },
      "required": ["title", "reporterId", "lat", "lng", "status"]
    },
    "Activity": {
      "title": "Activity",
      "description": "A community activity or event",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "location": { "type": "string" },
        "participants": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["title", "date", "location"]
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": "TrashReport",
      "description": "Collection of user-submitted trash reports"
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Collection of community activities"
    }
  }
}
