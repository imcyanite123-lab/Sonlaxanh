rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Collection Points (Official)
    match /collection_points/{pointId} {
      allow read: if true;
      allow write: if isSignedIn(); // In a real app, this would be isAdmin()
    }

    // Trash Reports
    match /reports/{reportId} {
      allow read: if true;
      allow create: if isSignedIn() 
        && incoming().reporterId == request.auth.uid
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (
        isOwner(existing().reporterId) && incoming().reporterId == existing().reporterId
        || incoming().diff(existing()).affectedKeys().hasOnly(['status']) // Allow status updates (e.g. verified/cleaned)
      );
      allow delete: if isOwner(existing().reporterId);
    }

    // Activities
    match /activities/{activityId} {
      allow read: if true;
      allow write: if isSignedIn(); // In a real app, this would be isAdmin()
    }
  }
}
